# Zmień nazwę tego pliku na .env po jego zaktualizowaniu!

############
# [wymagane] 
# Dane uwierzytelniające n8n - użyj komendy `openssl rand -hex 32` aby wygenerować oba
#   openssl jest domyślnie dostępny na Linux/Mac
#   Na Windows możesz użyć terminala 'Git Bash' zainstalowanego z gitem
#   Lub uruchom komendę: python -c "import secrets; print(secrets.token_hex(32))"
############

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Opcjonalnie: adres webhooków n8n (używany przez N8N_EDITOR_BASE_URL i WEBHOOK_URL)
# N8N_WEBHOOK_URL=https://n8n.yourdomain.com


############
# [wymagane]
# Sekrety Supabase

# MUSISZ JE ZMIENIĆ PRZED WDROŻENIEM NA PRODUKCJĘ
# Przeczytaj tę dokumentację w razie potrzeby: https://supabase.com/docs/guides/self-hosting/docker
# Dla JWT Secret i kluczy, zobacz: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Dla pozostałych sekretów, zobacz: https://supabase.com/docs/guides/self-hosting/docker#update-secrets
# Możesz ustawić dowolną wartość dla POOLER_TENANT_ID, na przykład 1000.

# Pamiętaj, że użycie znaków specjalnych (jak '%') może skomplikować hasło Postgres.
# Jeśli używasz znaków specjalnych w haśle Postgres, musisz pamiętać o zakodowaniu hasła procentowo w przypadku użycia connection stringa Postgres, na przykład: postgresql://postgres.projectref:p%3Dword@aws-0-us-east-1.pooler.supabase.com:6543/postgres
############

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated
POOLER_TENANT_ID=your-tenant-id
PG_META_CRYPTO_KEY=your-pg-meta-crypto-key

############
# [wymagane]
# Magazyn Supabase Storage
# Te zmienne są wymagane przez najnowszy kontener supabase storage-api.
# Domyślne wartości "stub" działają prawidłowo przy przechowywaniu plików lokalnie (nie S3).
# Dla kluczy dostępu protokołu S3 wygeneruj bezpieczne wartości na produkcji.
# Dokumentacja: https://supabase.com/docs/guides/self-hosting/self-hosted-s3
############

GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
S3_PROTOCOL_ACCESS_KEY_ID=625729a08b95bf1b7ff351a663f3a23c
S3_PROTOCOL_ACCESS_KEY_SECRET=850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907

############
# [wymagane na produkcji]
# Konfiguracja Caddy

# Domyślnie nasłuchuje na https://localhost:[port usługi] i nie używa emaila do SSL
# Aby zmienić to na produkcji:
# Odkomentuj zmienne środowiskowe dla usług, które chcesz udostępnić
# Zastąp wartość zastępczą hostem dla każdej usługi (np. n8n.twojadomena.com)
# Zastąp internal swoim adresem email (wymagane do utworzenia certyfikatu Let's Encrypt)
############

# N8N_HOSTNAME=n8n.yourdomain.com
# SUPABASE_HOSTNAME=supabase.yourdomain.com
# PORTAINER_HOSTNAME=portainer.yourdomain.com
# DOCLING_HOSTNAME=docling.yourdomain.com
# LETSENCRYPT_EMAIL=internal



############
# Docling Serve - API konwersji dokumentów (RAG)
############

# Klucz API do zabezpieczenia endpointów — wymagany nagłówek X-Api-Key
# Wygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
DOCLING_API_KEY=your-docling-api-key

# Basic Auth dla /docs i /ui (hash bcrypt generowany automatycznie przez start_services.py)
DOCLING_BASIC_AUTH_USER=admin
DOCLING_BASIC_AUTH_PASS=changeme

# Ustawienia wydajności CPU (dostosuj DOCLING_NUM_THREADS do liczby rdzeni VPS)
DOCLING_NUM_THREADS=4
DOCLING_MAX_PAGES=100
DOCLING_MAX_FILE_SIZE=52428800

# Wszystko poniżej tego punktu jest opcjonalne.
# Domyślne wartości wystarczą, chyba że potrzebujesz więcej funkcji/personalizacji.

   #
   #
#######
 #####
   #

############
# Opcjonalne uwierzytelnianie Google dla Supabase
# Pobierz te wartości z konsoli Google Admin
############
# ENABLE_GOOGLE_SIGNUP=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

############
# Baza danych - Możesz zmienić to na dowolną bazę PostgreSQL z włączoną replikacją logiczną.
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# domyślny użytkownik to postgres
POSTGRES_USER=postgres

############
# Supavisor -- Pooler bazy danych i inne wartości, które mogą pozostać domyślne
############
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq
VAULT_ENC_KEY=your-32-character-encryption-key
# Rozmiar puli dla wewnętrznego magazynu metadanych używanego przez Supavisor
# Jest to oddzielone od połączeń klienta i używane tylko przez sam Supavisor
POOLER_DB_POOL_SIZE=5


############
# Proxy API - Konfiguracja reverse proxy Kong.
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443


############
# API - Konfiguracja PostgREST.
############

PGRST_DB_SCHEMAS=public,storage,graphql_public


############
# Auth - Konfiguracja serwera uwierzytelniania GoTrue.
############

## Ogólne
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://localhost:8000

## Konfiguracja mailera
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Uwierzytelnianie emailowe
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Uwierzytelnianie telefoniczne
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

## Szablony e-mail (URL do plików HTML serwowanych przez Caddy lub CDN)
# Pozostaw puste, aby używać domyślnych szablonów Supabase.
# GOTRUE_MAILER_TEMPLATES_INVITE=https://yourdomain.com/templates/invite.html
# GOTRUE_MAILER_TEMPLATES_CONFIRMATION=https://yourdomain.com/templates/confirmation.html
# GOTRUE_MAILER_TEMPLATES_RECOVERY=https://yourdomain.com/templates/recovery.html
# GOTRUE_MAILER_TEMPLATES_EMAIL_CHANGE=https://yourdomain.com/templates/email_change.html
# GOTRUE_MAILER_TEMPLATES_MAGIC_LINK=https://yourdomain.com/templates/magic_link.html

## Tematy e-mail (niestandardowe tematy wiadomości)
# Pozostaw puste, aby używać domyślnych tematów Supabase.
# GOTRUE_MAILER_SUBJECTS_INVITE=Zaproszenie do aplikacji
# GOTRUE_MAILER_SUBJECTS_CONFIRMATION=Potwierdź rejestrację
# GOTRUE_MAILER_SUBJECTS_RECOVERY=Resetowanie hasła
# GOTRUE_MAILER_SUBJECTS_MAGIC_LINK=Twój link do logowania
# GOTRUE_MAILER_SUBJECTS_EMAIL_CHANGE=Potwierdź zmianę adresu e-mail


############
# Studio - Konfiguracja panelu Dashboard
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

STUDIO_PORT=3000
# zmień, jeśli zamierzasz używać Studio poza localhost
SUPABASE_PUBLIC_URL=http://localhost:8000

# Włącz obsługę webp
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Dodaj swój klucz API OpenAI, aby włączyć asystenta edytora SQL
OPENAI_API_KEY=


############
# Funkcje - Konfiguracja funkcji
############
# UWAGA: VERIFY_JWT dotyczy wszystkich funkcji. Indywidualne VERIFY_JWT dla poszczególnych funkcji nie jest jeszcze obsługiwane.
FUNCTIONS_VERIFY_JWT=false


############
# Logi - Konfiguracja analityki
# Zapoznaj się z https://supabase.com/docs/reference/self-hosting-analytics/introduction
############

# Zmień sink-i w vector.toml, aby odzwierciedlić tę zmianę
# te wartości nie mogą być takie same
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# Lokalizacja gniazda Docker - ta wartość będzie się różnić w zależności od systemu operacyjnego
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Szczegóły projektu Google Cloud
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
